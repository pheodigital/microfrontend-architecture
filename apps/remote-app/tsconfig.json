{
  // Same pattern as host-app — inherit from base, add app-specific overrides.
  "extends": "../../tsconfig.base.json",

  "compilerOptions": {
    "paths": {
      "@/*": ["./*"]
    },
    "baseUrl": "."
  },

  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts"
  ],

  "exclude": ["node_modules"]
}
